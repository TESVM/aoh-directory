{
  "name": "aoh-directory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3006",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:preflight": "npm run lint && npm run build && npm run check:firebase",
    "check:firebase": "node --env-file=.env.local ./scripts/check-firebase-config.mjs",
    "seed:firestore": "node --env-file=.env.local ./scripts/seed-firestore.mjs",
    "create:district-leader": "node --env-file=.env.local ./scripts/create-district-leader.mjs",
    "import:churches": "node --env-file=.env.local ./scripts/import-churches-from-csv.mjs",
    "import:html": "node --env-file=.env.local ./scripts/import-churches-from-html.mjs",
    "find:duplicates": "node --env-file=.env.local ./scripts/find-duplicate-churches.mjs",
    "cleanup:duplicates": "node --env-file=.env.local ./scripts/cleanup-duplicate-churches.mjs",
    "upsert:roll-call": "node --env-file=.env.local ./scripts/upsert-roll-call-churches.mjs"
  },
  "dependencies": {
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "firebase-tools": "^15.15.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vercel": "^51.4.0"
  }
}
